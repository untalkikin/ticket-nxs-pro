# ── Copia este archivo como .env y completa los valores ──────────────────────
# Railway: configura estas variables en el panel de tu servicio.

# Django
SECRET_KEY=cambia-esto-por-una-clave-secreta-segura
DEBUG=False
ALLOWED_HOSTS=tu-app.railway.app
CSRF_TRUSTED_ORIGINS=https://tu-app.railway.app

# Zona horaria / Idioma (opcional, ya definido en settings.py)
# TIME_ZONE=America/Mexico_City

# Base de datos SQLite
# Deja vacío para usar db.sqlite3 en el directorio del proyecto.
# Para persistencia en Railway: crea un volumen en /data y pon:
# DB_PATH=/data/db.sqlite3
DB_PATH=

# Mercado Pago
# Credenciales de PRUEBA:  https://www.mercadopago.com.mx/developers/panel/credentials
# Credenciales de PRODUCCIÓN: misma URL, pestaña "Producción"
MP_ACCESS_TOKEN=TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MP_PUBLIC_KEY=TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MP_CURRENCY=MXN

# URL pública de tu app (para los webhooks de Mercado Pago)
SITE_URL=https://tu-app.railway.app
